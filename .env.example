# ======================================================================
# mybatis-plus-stream — 环境变量模板
# ======================================================================
# 仓库代码不包含任何真实凭据，数据库账号密码一律通过下列环境变量注入。
#
# 用法：
#   1. 复制本文件为 .env          cp .env.example .env
#   2. 在 .env 中填入真实值（.env 已被 .gitignore 忽略，不会提交）
#   3. 加载到当前 shell：
#        Linux / macOS   set -a; source .env; set +a
#        Windows PowerShell  Get-Content .env | ForEach-Object {
#                              if ($_ -match '^\s*([^#][^=]*)=(.*)$') {
#                                [Environment]::SetEnvironmentVariable($matches[1].Trim(), $matches[2].Trim()) } }
#      也可使用 IDE 的 EnvFile 插件 / direnv 自动加载。
#
# 注：Maven Central / GPG 发布凭据不在此文件，已由 GitHub Actions Secrets 管理。
# ----------------------------------------------------------------------

# --- examples/quickstart 示例工程（本地 MySQL）---------------------------
MYSQL_USER=root
MYSQL_PASSWORD=

# --- test 模块 · MySQL 集成测试 -----------------------------------------
# 对应系统属性 mps.mysql.* / 环境变量 MPS_MYSQL_*
MPS_MYSQL_URL=jdbc:mysql://127.0.0.1:3306/mybatis_plus_stream_it?createDatabaseIfNotExist=true&useUnicode=true&characterEncoding=utf8&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai
MPS_MYSQL_USERNAME=root
MPS_MYSQL_PASSWORD=

# --- test 模块 · 达梦(DM) 集成测试 --------------------------------------
# 对应系统属性 mps.dm.* / 环境变量 MPS_DM_*
MPS_DM_URL=jdbc:dm://127.0.0.1:5236
MPS_DM_USERNAME=SYSDBA
MPS_DM_PASSWORD=
